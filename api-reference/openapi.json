{
  "openapi": "3.1.0",
  "info": {
    "title": "Kernel API",
    "description": "API for resolving company identity and retrieving entity data asynchronously",
    "version": "1.0.0",
    "contact": {
      "email": "support@kernel.ai"
    },
    "license": {
      "name": "MIT"
    }
  },
  "servers": [
    {
      "url": "https://api.kernel.ai",
      "description": "Production"
    }
  ],
  "tags": [
    {
      "name": "Entity Resolution",
      "description": "Resolve a company to a canonical entity"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/v1/entity-resolution": {
      "post": {
        "operationId": "resolveEntity",
        "tags": ["Entity Resolution"],
        "summary": "Resolve entity",
        "description": "Starts an entity resolution job for a company. Returns immediately with a job ID — poll `GET /v1/entity-resolution/{job_id}` until the status is `completed`.",
        "x-mint": {
          "content": "## Completed result\n\nThis endpoint returns `202` with a `job_id` immediately. Poll `GET /v1/entity-resolution/{job_id}` until `status` is `completed`, then read the result:\n\n```json\n{\n  \"job_id\": \"job_abc123\",\n  \"status\": \"completed\",\n  \"result\": {\n    \"kernel_id\": \"6347422643\",\n    \"match_status\": \"matched\",\n    \"legal_name\": \"Acme Corporation Inc.\",\n    \"trading_name\": \"Acme\"\n  }\n}\n```\n\nSee the [Completed result](/api-reference/schemas/entity-resolution-result) page for the full schema."
        },
        "requestBody": {
          "description": "Company to resolve",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/EntityResolutionRequest"
              },
              "examples": {
                "minimal": {
                  "summary": "Minimal — name only",
                  "value": {
                    "name": "Acme Corporation"
                  }
                },
                "full": {
                  "summary": "Full — all fields",
                  "value": {
                    "name": "Acme Corporation",
                    "website": "https://acme.com",
                    "legal_name": "Acme Corporation Inc.",
                    "linkedin_url": "https://linkedin.com/company/acme",
                    "email": "info@acme.com",
                    "address": "123 Main St",
                    "city": "San Francisco",
                    "state": "CA",
                    "country": "US"
                  }
                }
              }
            }
          },
          "required": true
        },
        "responses": {
          "202": {
            "description": "Job created",
            "headers": {
              "Location": {
                "description": "URI of the created job resource",
                "schema": {
                  "type": "string",
                  "example": "/v1/entity-resolution/job_abc123"
                }
              },
              "Retry-After": {
                "description": "Suggested interval in seconds before polling the job status",
                "schema": {
                  "type": "integer",
                  "example": 2
                }
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/JobCreatedResponse"
                },
                "example": {
                  "job_id": "job_abc123"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request — missing required field or malformed input",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "examples": {
                  "missing_name": {
                    "summary": "Missing required field",
                    "value": {
                      "error": 400,
                      "message": "Request body must include 'name'."
                    }
                  },
                  "empty_name": {
                    "summary": "Empty name",
                    "value": {
                      "error": 400,
                      "message": "'name' must not be empty."
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized — missing or invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "example": {
                  "error": 401,
                  "message": "Invalid API key."
                }
              }
            }
          },
          "429": {
            "description": "Rate limit exceeded",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "example": {
                  "error": 429,
                  "message": "Rate limit exceeded. Retry after 60 seconds."
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "example": {
                  "error": 500,
                  "message": "Internal processing error. Please retry."
                }
              }
            }
          }
        }
      }
    },
    "/v1/entity-resolution/{job_id}": {
      "get": {
        "operationId": "getEntityResolution",
        "tags": ["Entity Resolution"],
        "summary": "Get entity resolution result",
        "description": "Returns the status and result of an entity resolution job. When `status` is `completed`, the `result` object contains the resolved entity data.",
        "x-mint": {
          "content": "## Status lifecycle\n\nJobs follow a linear progression to a terminal state:\n\n```\npending → processing → completed | failed\n```\n\nOnce a job reaches `completed` or `failed`, the status does not change.\n\n## Polling guidance\n\n- Respect the `Retry-After` header from the creation response.\n- Use exponential backoff if the header is absent: start at 2 seconds, double up to 30 seconds.\n- If a job has not completed within 60 seconds, treat it as failed and retry or contact support.\n- Job results are available for **24 hours** after creation."
        },
        "parameters": [
          {
            "name": "job_id",
            "in": "path",
            "description": "ID of the entity resolution job",
            "required": true,
            "schema": {
              "type": "string",
              "pattern": "^job_",
              "example": "job_abc123"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Job status response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EntityResolutionJobStatus"
                },
                "examples": {
                  "pending": {
                    "summary": "Job pending",
                    "value": {
                      "job_id": "job_abc123",
                      "status": "pending"
                    }
                  },
                  "processing": {
                    "summary": "Job processing",
                    "value": {
                      "job_id": "job_abc123",
                      "status": "processing"
                    }
                  },
                  "completed_matched": {
                    "summary": "Completed — matched",
                    "value": {
                      "job_id": "job_abc123",
                      "status": "completed",
                      "result": {
                        "kernel_id": "6347422643",
                        "match_status": "matched",
                        "legal_name": "Acme Corporation Inc.",
                        "trading_name": "Acme"
                      }
                    }
                  },
                  "completed_no_match": {
                    "summary": "Completed — no match",
                    "value": {
                      "job_id": "job_abc123",
                      "status": "completed",
                      "result": {
                        "kernel_id": null,
                        "match_status": "no_match",
                        "legal_name": null,
                        "trading_name": null
                      }
                    }
                  },
                  "completed_ambiguous": {
                    "summary": "Completed — ambiguous",
                    "value": {
                      "job_id": "job_abc123",
                      "status": "completed",
                      "result": {
                        "kernel_id": null,
                        "match_status": "ambiguous",
                        "legal_name": null,
                        "trading_name": null
                      }
                    }
                  },
                  "failed": {
                    "summary": "Job failed",
                    "value": {
                      "job_id": "job_abc123",
                      "status": "failed",
                      "error": {
                        "error": 500,
                        "message": "Internal processing error"
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized — missing or invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "example": {
                  "error": 401,
                  "message": "Invalid API key."
                }
              }
            }
          },
          "404": {
            "description": "Job not found — the job ID does not exist or has expired",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "example": {
                  "error": 404,
                  "message": "Job not found."
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "example": {
                  "error": 500,
                  "message": "Internal processing error. Please retry."
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "EntityResolutionRequest": {
        "type": "object",
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "description": "The company name to resolve. This can be a legal name, trading name, or common abbreviation. Names are normalized automatically — case, punctuation, and common suffixes (Inc., LLC, Ltd.) do not need to be stripped.",
            "type": "string",
            "minLength": 1,
            "maxLength": 500,
            "example": "Acme Corporation"
          },
          "website": {
            "description": "Company website URL, including scheme.",
            "type": "string",
            "format": "uri",
            "maxLength": 2048,
            "example": "https://acme.com"
          },
          "legal_name": {
            "description": "Legal or registered name of the company, if known. Useful when the trading name differs from the registered entity.",
            "type": "string",
            "maxLength": 500,
            "example": "Acme Corporation Inc."
          },
          "linkedin_url": {
            "description": "LinkedIn company page URL. Personal profile URLs are not used for matching.",
            "type": "string",
            "format": "uri",
            "maxLength": 2048,
            "example": "https://linkedin.com/company/acme"
          },
          "email": {
            "description": "An email address at the company's domain. Only the domain portion is used for matching.",
            "type": "string",
            "format": "email",
            "maxLength": 254,
            "example": "info@acme.com"
          },
          "address": {
            "description": "Street address line.",
            "type": "string",
            "maxLength": 500,
            "example": "123 Main St"
          },
          "city": {
            "description": "City.",
            "type": "string",
            "maxLength": 200,
            "example": "San Francisco"
          },
          "state": {
            "description": "State, province, or region. Full name or code accepted.",
            "type": "string",
            "maxLength": 200,
            "example": "CA"
          },
          "country": {
            "description": "ISO 3166-1 alpha-2 country code preferred. Full names also accepted.",
            "type": "string",
            "maxLength": 100,
            "example": "US"
          }
        }
      },
      "JobCreatedResponse": {
        "required": [
          "job_id"
        ],
        "type": "object",
        "properties": {
          "job_id": {
            "description": "Unique identifier for the created job. Prefixed with `job_`.",
            "type": "string",
            "example": "job_abc123"
          }
        }
      },
      "EntityResolutionResult": {
        "required": [
          "kernel_id",
          "match_status",
          "legal_name",
          "trading_name"
        ],
        "type": "object",
        "properties": {
          "kernel_id": {
            "description": "The KERN ID — a persistent, 10-digit numeric identifier that uniquely identifies the resolved entity. The same legal entity always resolves to the same KERN ID. Null when `match_status` is `no_match` or `ambiguous`.",
            "type": [
              "string",
              "null"
            ],
            "example": "6347422643"
          },
          "match_status": {
            "description": "Outcome of the resolution",
            "type": "string",
            "enum": [
              "matched",
              "no_match",
              "ambiguous"
            ]
          },
          "legal_name": {
            "description": "Registered legal name of the resolved entity. Null when `match_status` is `no_match` or `ambiguous`.",
            "type": [
              "string",
              "null"
            ],
            "example": "Acme Corporation Inc."
          },
          "trading_name": {
            "description": "Primary trading or brand name of the resolved entity. Null when `match_status` is `no_match` or `ambiguous`.",
            "type": [
              "string",
              "null"
            ],
            "example": "Acme"
          }
        }
      },
      "EntityResolutionJobStatus": {
        "title": "Entity resolution",
        "required": [
          "job_id",
          "status"
        ],
        "type": "object",
        "properties": {
          "job_id": {
            "description": "Unique identifier for the job",
            "type": "string",
            "example": "job_abc123"
          },
          "status": {
            "description": "Current status of the job. Terminal states are `completed` and `failed`.",
            "type": "string",
            "enum": [
              "pending",
              "processing",
              "completed",
              "failed"
            ]
          },
          "result": {
            "description": "Result payload. Present when `status` is `completed`.",
            "$ref": "#/components/schemas/EntityResolutionResult"
          },
          "error": {
            "description": "Error details. Present when `status` is `failed`.",
            "$ref": "#/components/schemas/Error"
          }
        }
      },
      "Error": {
        "required": [
          "error",
          "message"
        ],
        "type": "object",
        "properties": {
          "error": {
            "description": "HTTP status code or application error code.",
            "type": "integer",
            "format": "int32",
            "example": 400
          },
          "message": {
            "description": "Human-readable error description.",
            "type": "string",
            "example": "Request body must include 'name'."
          }
        }
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Include your API key as a Bearer token in the Authorization header."
      }
    }
  }
}
